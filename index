<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Andre Kim Kessel</title>
    <style>
        :root {
            --bg: #ffffff;
            --text: #1a1a1a;
            --accent: #0070f3;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            background-color: var(--bg);
            color: var(--text);
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            text-align: center;
        }

        .container {
            max-width: 600px;
            padding: 20px;
        }

        h1 {
            font-size: 2.5rem;
            margin-bottom: 0.5rem;
            letter-spacing: -1px;
        }

        p {
            font-size: 1.2rem;
            color: #666;
            margin-bottom: 2rem;
        }

        .links {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        a {
            text-decoration: none;
            color: var(--text);
            padding: 12px 20px;
            border: 1px solid #eaeaea;
            border-radius: 8px;
            transition: all 0.2s ease;
        }

        a:hover {
            border-color: var(--accent);
            color: var(--accent);
            background-color: #fafafa;
        }
    </style>
</head>
<body>

    <div class="container">
        <h1>Andre Kim Kessel</h1>
        <p>Hi there!</p>
        
        <nav class="links">
            <a href="https://github.com/your-username">GitHub</a>
            <a href="mailto:hi@andrekimkessel.com">Contact Me</a>
        </nav>
    </div>

</body>
</html>
